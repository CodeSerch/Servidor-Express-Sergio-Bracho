<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head'); %>
</head>

<body class="container">

    <header>
        <%- include('../partials/header'); %>
    </header>

    <main>
        <div class="jumbotron">
            <h1>This is great</h1>
            <p>Welcome to templating using EJS</p>
            -vista: home
            <h1>Inicio</h1>
            <h1>Formulario para agregar Productos</h1>
            <form action="/addProducto" method="post">
                Ingrese el nombre del Producto:
                <input type="text" name="title" size="10"><br>
                Ingrese el precio del producto:
                <input type="text" name="price" size="10"><br>
                Ingresa la url de la imagen
                <input type="text" name="imgUrl" size="10"><br>
                <input type="submit" />
            </form>
            <br />
            <a href="/productos">ver productos</a>
        </div>
    </main>

    <footer>
        <%- include('../partials/footer'); %>
    </footer>

</body>

</html>